{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Murmr",
  "version": "0.1.17",
  "identifier": "app.murmr.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Murmr",
        "url": "index.html",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "center": true
      },
      {
        "label": "hud",
        "title": "Murmr HUD",
        "url": "hud.html",
        "width": 380,
        "height": 76,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": false,
        "shadow": false
      },
      {
        "label": "onboarding",
        "title": "Welcome to Murmr",
        "url": "onboarding.html",
        "width": 720,
        "height": 600,
        "decorations": false,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "visible": false,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": true,
    "resources": {
      "models/*.bin": "models/",
      "runtime/windows/vcomp140.dll": "./vcomp140.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "http://127.0.0.1:8123/latest.json",
        "https://github.com/composrr/Murmr/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxRUUwODM3QTM3RTlBMTEKUldRUm1uNmpOd2p1WVY3NlpjeWVyUkp4YkZwNGo2QzBzSUFlV0c0RkJWalBhbHpIMXJVY0g5N0EK",
      "dangerousInsecureTransportProtocol": true
    }
  }
}
